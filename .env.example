# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_USER=finuser
POSTGRES_PASSWORD=finpassword
POSTGRES_DB=findb

# ─────────────────────────────────────────
# pgAdmin
# ─────────────────────────────────────────
PGADMIN_EMAIL=admin@fin.local
PGADMIN_PASSWORD=adminpass

# ─────────────────────────────────────────
# JWT / Security
# ─────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────
# LLM Providers
# Escolha o provider padrão: ollama | deepseek | gemini
# ─────────────────────────────────────────
DEFAULT_LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# DeepSeek V3
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Google Gemini 2.5 Flash
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_NAME=FinSecAI
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
